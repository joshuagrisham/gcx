{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Grafana On-Prem Auth",
  "id": "grafana-on-prem-auth-app",
  "info": {
    "description": "Issues per-user Grafana service-account tokens to the gcx CLI via a browser sign-in flow.",
    "author": {
      "name": "gcx maintainers",
      "url": "https://github.com/grafana/gcx"
    },
    "keywords": ["cli", "auth", "gcx"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "0.1.0",
    "updated": "2026-05-16"
  },
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  },
  "backend": true,
  "executable": "gpx_grafana_on_prem_auth_app",
  "iam": {
    "permissions": [
      { "action": "serviceaccounts:read" },
      { "action": "serviceaccounts:write" },
      { "action": "serviceaccounts:create" },
      { "action": "serviceaccounts.permissions:write" },
      { "action": "orgs:read" },
      { "action": "users:read" }
    ]
  },
  "includes": [
    {
      "type": "page",
      "name": "CLI sign-in",
      "path": "/a/grafana-on-prem-auth-app/cli",
      "addToNav": false,
      "defaultNav": false,
      "role": "Viewer"
    }
  ],
  "routes": []
}
